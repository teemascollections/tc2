// ─── NAVBAR ───────────────────────────────────────────────────────────────────
function Navbar({page,setPage,cartCount,wishCount,searchQ,setSearchQ,mobileOpen,setMobileOpen}){
  const [scrolled,setScrolled]=useState(false);
