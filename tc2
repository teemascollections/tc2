            />
            <span style={{position:"absolute",left:10,top:"50%",transform:"translateY(-50%)",color:C.muted}}>{Icon.search()}</span>
          </div>}
          <IconBtn onClick={()=>{setSearchOpen(!searchOpen);if(searchOpen){setSearchQ("");} else {setPage("shop");}}}>{Icon.search()}</IconBtn>
        </div>

        {/* Icons */}
        <IconBtn onClick={()=>setPage("wishlist")} badge={wishCount}>{Icon.heart(wishCount>0)}</IconBtn>
        <IconBtn onClick={()=>setPage("cart")} badge={cartCount}>{Icon.bag()}</IconBtn>
        <div className="hide-mobile">
          <Btn size="sm" variant="outline" onClick={()=>setPage("admin")} style={{fontSize:11,letterSpacing:".08em",textTransform:"uppercase"}}>Admin</Btn>
        </div>
        {/* Mobile menu */}
        <button className="hide-desktop" onClick={()=>setMobileOpen(!mobileOpen)} style={{background:"none",border:"none",cursor:"pointer",color:C.dark}}>{Icon.menu()}</button>
      </div>

      {/* Mobile menu */}
