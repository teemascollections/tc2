// ─── SHOP PAGE ────────────────────────────────────────────────────────────────
function ShopPage({products,onView,onCart,onWish,wishlist,searchQ,setCatFilter,catFilter}){
  const [cat,setCat]=useState(catFilter||"all");
  const [sizes,setSizes]=useState([]);
  const [avail,setAvail]=useState([]);
  const [price,setPrice]=useState([0,1000]);
  const [sort,setSort]=useState("newest");
  const [loading,setLoading]=useState(true);
  const [filterOpen,setFilterOpen]=useState(false);

  useEffect(()=>{setCat(catFilter||"all");},[catFilter]);
  useEffect(()=>{const t=setTimeout(()=>setLoading(false),400);return()=>clearTimeout(t);},[]);

  const toggleSize=s=>setSizes(p=>p.includes(s)?p.filter(x=>x!==s):[...p,s]);
  const toggleAvail=a=>setAvail(p=>p.includes(a)?p.filter(x=>x!==a):[...p,a]);

  let filtered=products.filter(p=>{
    if(cat!=="all"&&p.category!==cat)return false;
    if(sizes.length&&!sizes.some(s=>p.sizes.includes(s)))return false;
    if(avail.length&&!avail.includes(p.availability))return false;
    if(p.price<price[0]||p.price>price[1])return false;
    if(searchQ){const q=searchQ.toLowerCase();if(!p.name.toLowerCase().includes(q)&&!p.description.toLowerCase().includes(q)&&!p.category.includes(q))return false;}
    return true;
  });
  filtered=[...filtered].sort((a,b)=>{
    if(sort==="newest")return b.createdAt-a.createdAt;
    if(sort==="price-asc")return a.price-b.price;
    if(sort==="price-desc")return b.price-a.price;
    return 0;
  });

  const FilterPanel=()=>(
    <div style={{background:C.white,borderRadius:16,padding:24,border:`1px solid ${C.border}`}}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:20}}>
        <h3 style={{fontSize:14,fontWeight:600,color:C.dark,letterSpacing:".04em",textTransform:"uppercase"}}>Filters</h3>
        <button onClick={()=>{setCat("all");setSizes([]);setAvail([]);setPrice([0,1000]);}} style={{background:"none",border:"none",cursor:"pointer",fontSize:11,color:C.gold,textDecoration:"underline"}}>Clear all</button>
      </div>
      {/* Category */}
      <div style={{marginBottom:24}}>
        <p style={{fontSize:11,letterSpacing:".08em",textTransform:"uppercase",color:C.muted,fontWeight:600,marginBottom:10}}>Category</p>
        {[{id:"all",label:"All Pieces"},...CATS].map(c=>(
          <button key={c.id} onClick={()=>setCat(c.id)} style={{display:"flex",alignItems:"center",gap:8,width:"100%",background:"none",border:"none",cursor:"pointer",padding:"6px 0",fontSize:13,color:cat===c.id?C.gold:C.text,fontWeight:cat===c.id?600:400,transition:"color .15s"}}>
            <span style={{width:14,height:14,borderRadius:3,border:`1.5px solid ${cat===c.id?C.gold:C.border}`,background:cat===c.id?C.gold:"transparent",display:"flex",alignItems:"center",justifyContent:"center",flexShrink:0}}>
              {cat===c.id&&<svg width="8" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4l2.5 3L9 1" stroke="#fff" strokeWidth="1.5" strokeLinecap="round"/></svg>}
            </span>
            {c.label}
          </button>
        ))}
      </div>
      {/* Price range */}
      <div style={{marginBottom:24}}>
        <p style={{fontSize:11,letterSpacing:".08em",textTransform:"uppercase",color:C.muted,fontWeight:600,marginBottom:10}}>Price Range</p>
        <div style={{display:"flex",justifyContent:"space-between",marginBottom:8}}>
          <span style={{fontSize:12,color:C.text}}>{fmt(price[0])}</span>
          <span style={{fontSize:12,color:C.text}}>{fmt(price[1])}</span>
        </div>
        <input type="range" min={0} max={700} value={price[1]} onChange={e=>setPrice([price[0],+e.target.value])} className="range-input" style={{width:"100%"}}/>
      </div>
      {/* Sizes */}
      <div style={{marginBottom:24}}>
        <p style={{fontSize:11,letterSpacing:".08em",textTransform:"uppercase",color:C.muted,fontWeight:600,marginBottom:10}}>Sizes</p>
        <div style={{display:"flex",flexWrap:"wrap",gap:6}}>
          {SIZES_ALL.map(s=>(
            <button key={s} onClick={()=>toggleSize(s)} style={{padding:"5px 12px",borderRadius:6,border:`1.5px solid ${sizes.includes(s)?C.gold:C.border}`,background:sizes.includes(s)?C.goldL:C.white,fontSize:12,fontWeight:600,cursor:"pointer",color:sizes.includes(s)?C.goldD:C.text,transition:"all .15s"}}>{s}</button>
          ))}
        </div>
      </div>
      {/* Availability */}
      <div>
        <p style={{fontSize:11,letterSpacing:".08em",textTransform:"uppercase",color:C.muted,fontWeight:600,marginBottom:10}}>Availability</p>
        {Object.entries(AVAIL_MAP).map(([k,v])=>(
          <button key={k} onClick={()=>toggleAvail(k)} style={{display:"flex",alignItems:"center",gap:8,width:"100%",background:"none",border:"none",cursor:"pointer",padding:"6px 0",fontSize:13,color:avail.includes(k)?C.gold:C.text,fontWeight:avail.includes(k)?600:400}}>
            <span style={{width:14,height:14,borderRadius:"50%",border:`1.5px solid ${avail.includes(k)?C.gold:C.border}`,background:avail.includes(k)?C.gold:"transparent",flexShrink:0}}/>
            <span style={{color:v.c}}>{v.l}</span>
          </button>
        ))}
      </div>
    </div>
  );

  return <div style={{maxWidth:1280,margin:"0 auto",padding:"40px 24px"}} className="tc-fade">
    {/* Header */}
    <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:32,flexWrap:"wrap",gap:12}}>
      <div>
        <h1 className="tc-serif" style={{fontSize:"clamp(26px,4vw,40px)",color:C.dark,fontWeight:700}}>
          {searchQ?`Results for "${searchQ}"`:cat==="all"?"All Pieces":catLabel(cat)}
        </h1>
        <p style={{fontSize:13,color:C.muted,marginTop:4}}>{filtered.length} piece{filtered.length!==1?"s":""} found</p>
      </div>
      <div style={{display:"flex",gap:10,alignItems:"center"}}>
        <button className="hide-desktop" onClick={()=>setFilterOpen(!filterOpen)} style={{display:"flex",alignItems:"center",gap:6,padding:"8px 14px",border:`1.5px solid ${C.border}`,borderRadius:8,background:C.white,cursor:"pointer",fontSize:13,color:C.text}}>
          {Icon.filter()} Filters
        </button>
        <select value={sort} onChange={e=>setSort(e.target.value)} style={{padding:"8px 14px",border:`1.5px solid ${C.border}`,borderRadius:8,fontSize:13,background:C.white,color:C.text,cursor:"pointer",fontFamily:"'Jost',sans-serif"}}>
          <option value="newest">Newest First</option>
          <option value="price-asc">Price: Low → High</option>
          <option value="price-desc">Price: High → Low</option>
        </select>
      </div>
    </div>

    {/* Mobile filter panel */}
    {filterOpen&&<div className="hide-desktop tc-fade" style={{marginBottom:20}}><FilterPanel/></div>}

    <div style={{display:"grid",gridTemplateColumns:"240px 1fr",gap:28,alignItems:"start"}}>
      {/* Sidebar - desktop */}
      <div className="hide-mobile" style={{position:"sticky",top:80}}><FilterPanel/></div>

      {/* Product grid */}
      <div>
        {loading
          ?<div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(220px,1fr))",gap:20}}>
            {[...Array(6)].map((_,i)=><SkeletonCard key={i}/>)}
          </div>
          :filtered.length===0
            ?<div style={{textAlign:"center",padding:"80px 0",gridColumn:"1/-1"}}>
              <div style={{fontSize:48,marginBottom:16}}>🔍</div>
              <h3 className="tc-serif" style={{fontSize:22,color:C.muted,marginBottom:8}}>No pieces found</h3>
              <p style={{fontSize:14,color:C.muted}}>Try adjusting your filters or browse all pieces.</p>
              <Btn style={{marginTop:20}} onClick={()=>{setCat("all");setSizes([]);setAvail([]);setPrice([0,1000]);}}>Clear Filters</Btn>
            </div>
            :<div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(220px,1fr))",gap:20}}>
              {filtered.map(p=><ProductCard key={p.id} product={p} onView={onView} onCart={onCart} onWish={onWish} isWished={wishlist.includes(p.id)}/>)}
            </div>
        }
      </div>
    </div>
  </div>;
}

