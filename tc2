// ─── CHECKOUT PAGE ────────────────────────────────────────────────────────────
function CheckoutPage({cart,products,onOrderPlace,setPage}){
  const [form,setForm]=useState({name:"",email:"",phone:"",address:"",city:"",country:"Nigeria",payment:"card"});
  const [errors,setErrors]=useState({});
  const [placed,setPlaced]=useState(false);
  const [loading,setLoading]=useState(false);
  const items=cart.map(ci=>{const p=products.find(x=>x.id===ci.productId);return p?{...ci,product:p}:null;}).filter(Boolean);
  const subtotal=items.reduce((s,i)=>s+i.product.price*i.qty,0);
  const shipping=subtotal>100?0:12;
  const total=subtotal+shipping;

  const validate=()=>{
    const e={};
    if(!form.name.trim())e.name="Name is required";
    if(!form.email.match(/^\S+@\S+\.\S+$/))e.email="Valid email required";
    if(!form.address.trim())e.address="Address is required";
    if(!form.city.trim())e.city="City is required";
    return e;
  };

  const handleSubmit=()=>{
    const e=validate();
    if(Object.keys(e).length){setErrors(e);return;}
    setLoading(true);
    setTimeout(()=>{
      onOrderPlace({id:`ORD-${Date.now().toString(36).toUpperCase()}`,name:form.name,email:form.email,address:`${form.address}, ${form.city}, ${form.country}`,items:items.map(i=>({id:i.productId,name:i.product.name,size:i.size,qty:i.qty,price:i.product.price})),total,status:"processing",date:Date.now()});
      setPlaced(true);
      setLoading(false);
    },1800);
  };

  const F=({field,label,type="text",placeholder})=>(
    <div style={{marginBottom:16}}>
      <label className="tc-label">{label}</label>
      <input type={type} value={form[field]} onChange={e=>setForm({...form,[field]:e.target.value})} placeholder={placeholder} className="tc-input"/>
      {errors[field]&&<p style={{color:C.rose,fontSize:11,marginTop:3}}>{errors[field]}</p>}
    </div>
  );

  if(placed)return <div className="tc-fade" style={{textAlign:"center",padding:"80px 24px",maxWidth:520,margin:"0 auto"}}>
    <div style={{fontSize:64,marginBottom:16}}>🎉</div>
    <h2 className="tc-serif" style={{fontSize:32,color:C.dark,marginBottom:10}}>Order Placed!</h2>
    <p style={{fontSize:15,color:C.muted,lineHeight:1.7,marginBottom:8}}>Thank you, {form.name}. Your order has been received and is being processed.</p>
    <p style={{fontSize:13,color:C.gold,marginBottom:32}}>A confirmation will be sent to {form.email}</p>
    <Btn onClick={()=>setPage("home")}>Back to Home</Btn>
  </div>;

  if(items.length===0)return <div style={{textAlign:"center",padding:"80px 24px"}}>
    <p className="tc-serif" style={{fontSize:22,color:C.muted,marginBottom:16}}>Your bag is empty</p>
    <Btn onClick={()=>setPage("shop")}>Continue Shopping</Btn>
  </div>;

  return <div className="tc-fade" style={{maxWidth:1100,margin:"0 auto",padding:"40px 24px"}}>
    <div style={{marginBottom:32}}>
