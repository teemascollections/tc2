// ─── CART DRAWER ──────────────────────────────────────────────────────────────
function CartDrawer({open,onClose,cart,products,updateQty,removeItem,setPage}){
  const items=cart.map(ci=>{const p=products.find(x=>x.id===ci.productId);return p?{...ci,product:p}:null;}).filter(Boolean);
  const subtotal=items.reduce((s,i)=>s+i.product.price*i.qty,0);

  return <>
    {open&&<div className="tc-overlay" onClick={onClose}/>}
    <div style={{position:"fixed",top:0,right:0,height:"100vh",width:"min(420px,100vw)",background:C.white,zIndex:50,boxShadow:"-8px 0 40px rgba(42,26,20,.12)",display:"flex",flexDirection:"column",transform:open?"translateX(0)":"translateX(100%)",transition:"transform .35s cubic-bezier(.22,.68,0,1)"}}>
