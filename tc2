          <div style={{fontSize:8,letterSpacing:".25em",textTransform:"uppercase",color:C.gold,marginTop:1}}>Collections</div>
        </div>

        {/* Desktop nav links */}
        <div className="hide-mobile" style={{display:"flex",gap:32}}>
          {navLinks.map(n=>(
            <button key={n.id} onClick={()=>setPage(n.id.includes("?")?n.id.split("?")[0]:n.id)} className="tc-link"
              style={{background:"none",border:"none",cursor:"pointer",fontSize:13,fontWeight:500,letterSpacing:".06em",textTransform:"uppercase",color:page===n.id.split("?")[0]?C.gold:C.text,transition:"color .2s"}}>
              {n.l}
            </button>
          ))}
        </div>

        {/* Search bar (collapsible) */}
        <div style={{display:"flex",alignItems:"center",gap:8}}>
          {searchOpen&&<div style={{position:"relative"}} className="tc-scale-in">
