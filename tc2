function Toast({toasts,remove}){
  return <div style={{position:"fixed",bottom:24,right:24,zIndex:1000,display:"flex",flexDirection:"column",gap:10}}>
    {toasts.map(t=>(
      <div key={t.id} className="toast-enter" style={{background:C.dark,color:"#fff",padding:"12px 18px",borderRadius:12,fontSize:13,display:"flex",alignItems:"center",gap:10,minWidth:260,maxWidth:340,boxShadow:"0 8px 30px rgba(0,0,0,.25)"}}>
        <span style={{fontSize:18}}>{t.icon||"✓"}</span>
        <span style={{flex:1}}>{t.msg}</span>
        <button onClick={()=>remove(t.id)} style={{background:"none",border:"none",color:"rgba(255,255,255,.6)",cursor:"pointer",fontSize:16,lineHeight:1}}>×</button>
      </div>
    ))}
  </div>;
}

function useToast(){
  const [toasts,setToasts]=useState([]);
  const add=useCallback((msg,icon)=>{
    const id=Date.now();
    setToasts(p=>[...p,{id,msg,icon}]);
    setTimeout(()=>setToasts(p=>p.filter(t=>t.id!==id)),3500);
  },[]);
  const remove=useCallback(id=>setToasts(p=>p.filter(t=>t.id!==id)),[]);
  return {toasts,add,remove};
}

function Modal({open,onClose,title,children,width=520}){
  if(!open)return null;
  return <>
    <div className="tc-overlay" onClick={onClose}/>
    <div className="modal-enter" style={{position:"fixed",top:"50%",left:"50%",transform:"translate(-50%,-50%)",zIndex:50,background:C.white,borderRadius:20,width:`min(${width}px,95vw)`,maxHeight:"90vh",overflow:"auto",boxShadow:"0 25px 60px rgba(42,26,20,.25)"}}>
