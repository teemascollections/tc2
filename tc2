        <div>
          <h2 className="tc-serif" style={{fontSize:20,color:C.dark}}>Your Bag</h2>
          <p style={{fontSize:12,color:C.muted,marginTop:2}}>{items.length} item{items.length!==1?"s":""}</p>
        </div>
        <button onClick={onClose} style={{background:"none",border:"none",cursor:"pointer",color:C.muted,display:"flex"}}>{Icon.x()}</button>
      </div>

      {/* Items */}
      <div style={{flex:1,overflowY:"auto",padding:24}}>
        {items.length===0
          ?<div style={{textAlign:"center",padding:"60px 0"}}>
            <div style={{fontSize:48,marginBottom:12}}>🛍</div>
            <p className="tc-serif" style={{fontSize:18,color:C.muted}}>Your bag is empty</p>
            <p style={{fontSize:13,color:C.muted,marginTop:4}}>Add something beautiful</p>
            <Btn size="sm" onClick={()=>{onClose();setPage("shop");}} style={{marginTop:16}}>Browse Shop</Btn>
          </div>
          :items.map(item=>(
            <div key={`${item.productId}-${item.size}`} style={{display:"flex",gap:14,marginBottom:20,paddingBottom:20,borderBottom:`1px solid ${C.border}`}}>
              <img src={item.product.images[0]} alt={item.product.name} style={{width:80,height:100,objectFit:"cover",borderRadius:10}}/>
              <div style={{flex:1,minWidth:0}}>
                <h4 style={{fontSize:14,fontWeight:500,color:C.dark,marginBottom:3,lineHeight:1.3}}>{item.product.name}</h4>
                <p style={{fontSize:12,color:C.muted,marginBottom:8}}>Size: {item.size}</p>
                <div style={{display:"flex",alignItems:"center",justifyContent:"space-between"}}>
                  <div style={{display:"flex",alignItems:"center",gap:8,background:C.ivory,borderRadius:20,padding:"3px 8px"}}>
                    <button onClick={()=>updateQty(item.productId,item.size,item.qty-1)} style={{background:"none",border:"none",cursor:"pointer",color:C.text,display:"flex",width:22,height:22,alignItems:"center",justifyContent:"center"}}>{Icon.minus()}</button>
                    <span style={{fontSize:13,fontWeight:600,minWidth:16,textAlign:"center"}}>{item.qty}</span>
                    <button onClick={()=>updateQty(item.productId,item.size,item.qty+1)} style={{background:"none",border:"none",cursor:"pointer",color:C.text,display:"flex",width:22,height:22,alignItems:"center",justifyContent:"center"}}>{Icon.plus()}</button>
                  </div>
                  <div style={{display:"flex",alignItems:"center",gap:10}}>
                    <span style={{fontFamily:"'Playfair Display',serif",fontWeight:700,fontSize:15,color:C.gold}}>{fmt(item.product.price*item.qty)}</span>
                    <button onClick={()=>removeItem(item.productId,item.size)} style={{background:"none",border:"none",cursor:"pointer",color:"#C42A2A",display:"flex"}}>{Icon.trash()}</button>
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>

      {/* Footer */}
      {items.length>0&&<div style={{padding:24,borderTop:`1px solid ${C.border}`,background:C.bg}}>
        <div style={{display:"flex",justifyContent:"space-between",marginBottom:6}}>
          <span style={{fontSize:13,color:C.muted}}>Subtotal</span>
          <span style={{fontFamily:"'Playfair Display',serif",fontWeight:700,fontSize:18,color:C.dark}}>{fmt(subtotal)}</span>
        </div>
        <p style={{fontSize:11,color:C.muted,marginBottom:14}}>Shipping & taxes calculated at checkout</p>
        <Btn full size="lg" onClick={()=>{onClose();setPage("checkout");}}>
          Proceed to Checkout <span>{Icon.arrow()}</span>
        </Btn>
        <Btn full size="sm" variant="ghost" onClick={()=>{onClose();setPage("shop");}} style={{marginTop:8,color:C.muted}}>
          Continue Shopping
        </Btn>
      </div>}
    </div>
  </>;
}

