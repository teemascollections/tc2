function Btn({children,variant="primary",size="md",onClick,disabled,full,className="",style={},...p}){
  const base="tc-btn-hover font-medium rounded-lg cursor-pointer border-0 flex items-center justify-center gap-2 ";
  const sz={sm:"text-xs px-3 py-1.5",md:"text-sm px-5 py-2.5",lg:"text-base px-7 py-3.5"}[size];
  const v={
    primary:`text-white`,
    outline:`border bg-transparent`,
    ghost:`bg-transparent`,
    danger:`text-white`,
  };
  const vs={
    primary:{background:`linear-gradient(135deg,${C.gold},${C.goldD})`,color:"#fff",...style},
    outline:{border:`1.5px solid ${C.border}`,color:C.text,...style},
    ghost:{color:C.text,...style},
    danger:{background:"#C42A2A",color:"#fff",...style},
  };
  return <button onClick={onClick} disabled={disabled} className={`${base}${sz} ${v[variant]} ${full?"w-full":""} ${disabled?"opacity-50 cursor-not-allowed":""} ${className}`} style={vs[variant]} {...p}>{children}</button>;
}

