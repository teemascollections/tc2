function AdminProductForm({product,onSave,onCancel}){
  const blank={id:null,name:"",price:"",originalPrice:"",category:"luxury",description:"",sizes:[],availability:"in-stock",featured:false,images:[""],createdAt:Date.now()};
  const [form,setForm]=useState(product?{...product,price:String(product.price),originalPrice:product.originalPrice?String(product.originalPrice):"",images:product.images.length>0?product.images:[""]}:blank);
  const [errors,setErrors]=useState({});
  const [imgDrag,setImgDrag]=useState(false);

  const validate=()=>{
    const e={};
    if(!form.name.trim())e.name="Name required";
    if(!form.price||isNaN(+form.price)||+form.price<=0)e.price="Valid price required";
    if(!form.description.trim())e.description="Description required";
    if(form.sizes.length===0)e.sizes="Select at least one size";
    return e;
  };

  const toggleSize=s=>setForm(f=>({...f,sizes:f.sizes.includes(s)?f.sizes.filter(x=>x!==s):[...f.sizes,s]}));
  const setImg=(i,v)=>setForm(f=>({...f,images:f.images.map((img,idx)=>idx===i?v:img)}));
  const addImg=()=>setForm(f=>({...f,images:[...f.images,""]}));
  const removeImg=i=>setForm(f=>({...f,images:f.images.filter((_,idx)=>idx!==i)}));

  const handleFileUpload=(i,file)=>{
    if(!file||!file.type.startsWith("image/"))return;
    const reader=new FileReader();
    reader.onload=e=>setImg(i,e.target.result);
    reader.readAsDataURL(file);
  };

  const submit=()=>{
    const e=validate();
    if(Object.keys(e).length){setErrors(e);return;}
    const imgs=form.images.filter(Boolean);
    onSave({...form,id:form.id||uid(),price:+form.price,originalPrice:form.originalPrice?+form.originalPrice:null,images:imgs.length?imgs:["https://picsum.photos/seed/default/500/680"],createdAt:product?.createdAt||Date.now()});
  };

  return <div className="tc-fade">
    <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:24}}>
      <h2 className="tc-serif" style={{fontSize:24,color:C.dark}}>{product?"Edit Product":"Add New Product"}</h2>
      <Btn variant="outline" size="sm" onClick={onCancel}>Cancel</Btn>
    </div>
    <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(300px,1fr))",gap:24}}>
      {/* Left column */}
      <div>
        <div style={{background:C.white,borderRadius:16,padding:24,border:`1px solid ${C.border}`,marginBottom:20}}>
          <h4 style={{fontSize:13,fontWeight:700,color:C.dark,letterSpacing:".06em",textTransform:"uppercase",marginBottom:16}}>Product Details</h4>
          <div style={{marginBottom:14}}>
            <label className="tc-label">Product Name *</label>
            <input value={form.name} onChange={e=>setForm({...form,name:e.target.value})} placeholder="e.g. Vintage Silk Wrap Dress" className="tc-input"/>
            {errors.name&&<p style={{color:C.rose,fontSize:11,marginTop:3}}>{errors.name}</p>}
          </div>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12,marginBottom:14}}>
            <div>
              <label className="tc-label">Sale Price ($) *</label>
              <input type="number" value={form.price} onChange={e=>setForm({...form,price:e.target.value})} placeholder="89.00" className="tc-input"/>
              {errors.price&&<p style={{color:C.rose,fontSize:11,marginTop:3}}>{errors.price}</p>}
            </div>
            <div>
              <label className="tc-label">Original Price ($)</label>
              <input type="number" value={form.originalPrice} onChange={e=>setForm({...form,originalPrice:e.target.value})} placeholder="380.00 (optional)" className="tc-input"/>
            </div>
          </div>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12,marginBottom:14}}>
            <div>
              <label className="tc-label">Category *</label>
              <select value={form.category} onChange={e=>setForm({...form,category:e.target.value})} className="tc-input">
                {CATS.map(c=><option key={c.id} value={c.id}>{c.label}</option>)}
              </select>
            </div>
            <div>
              <label className="tc-label">Availability</label>
              <select value={form.availability} onChange={e=>setForm({...form,availability:e.target.value})} className="tc-input">
                {Object.entries(AVAIL_MAP).map(([k,v])=><option key={k} value={k}>{v.l}</option>)}
              </select>
            </div>
          </div>
          <div style={{marginBottom:14}}>
            <label className="tc-label">Description *</label>
            <textarea value={form.description} onChange={e=>setForm({...form,description:e.target.value})} placeholder="Describe the product…" className="tc-input" style={{resize:"vertical",minHeight:100}}/>
            {errors.description&&<p style={{color:C.rose,fontSize:11,marginTop:3}}>{errors.description}</p>}
          </div>
          {/* Sizes */}
          <div style={{marginBottom:14}}>
            <label className="tc-label">Available Sizes *</label>
            <div style={{display:"flex",flexWrap:"wrap",gap:7}}>
              {SIZES_ALL.map(s=>(
                <button key={s} type="button" onClick={()=>toggleSize(s)} style={{padding:"6px 14px",borderRadius:7,border:`1.5px solid ${form.sizes.includes(s)?C.gold:C.border}`,background:form.sizes.includes(s)?C.goldL:C.white,fontSize:12,fontWeight:700,cursor:"pointer",color:form.sizes.includes(s)?C.goldD:C.text,transition:"all .15s"}}>{s}</button>
              ))}
            </div>
            {errors.sizes&&<p style={{color:C.rose,fontSize:11,marginTop:4}}>{errors.sizes}</p>}
          </div>
          {/* Featured toggle */}
          <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",padding:"14px 16px",background:C.ivory,borderRadius:10}}>
            <div>
              <p style={{fontSize:13,fontWeight:500,color:C.dark}}>Feature on Homepage</p>
              <p style={{fontSize:11,color:C.muted}}>Show in featured products section</p>
            </div>
            <button type="button" onClick={()=>setForm(f=>({...f,featured:!f.featured}))} style={{width:44,height:24,borderRadius:12,border:"none",cursor:"pointer",background:form.featured?C.gold:"#ddd",transition:"background .2s",position:"relative",flexShrink:0}}>
              <span style={{position:"absolute",top:3,left:form.featured?22:3,width:18,height:18,borderRadius:"50%",background:"#fff",transition:"left .2s"}}/>
            </button>
          </div>
        </div>
      </div>

      {/* Right column - images */}
      <div>
        <div style={{background:C.white,borderRadius:16,padding:24,border:`1px solid ${C.border}`}}>
          <h4 style={{fontSize:13,fontWeight:700,color:C.dark,letterSpacing:".06em",textTransform:"uppercase",marginBottom:16}}>Product Images</h4>
          {form.images.map((img,i)=>(
            <div key={i} style={{marginBottom:16}}>
              {/* Drag drop zone */}
              <div onDragOver={e=>{e.preventDefault();setImgDrag(i);}} onDragLeave={()=>setImgDrag(false)}
                onDrop={e=>{e.preventDefault();setImgDrag(false);const f=e.dataTransfer.files[0];if(f)handleFileUpload(i,f);}}
                style={{border:`2px dashed ${imgDrag===i?C.gold:C.border}`,borderRadius:12,padding:12,background:imgDrag===i?C.goldL:C.ivory,marginBottom:8,transition:"all .2s",cursor:"pointer"}}
                onClick={()=>document.getElementById(`imgFile-${i}`).click()}>
                {img
                  ?<div style={{position:"relative"}}>
                    <img src={img} alt="" style={{width:"100%",height:160,objectFit:"cover",borderRadius:8}}
                      onError={e=>e.target.style.display="none"}/>
                    <div style={{position:"absolute",inset:0,background:"rgba(0,0,0,.0)",display:"flex",alignItems:"center",justifyContent:"center",borderRadius:8,opacity:0,transition:"opacity .2s"}}
                      onMouseEnter={e=>e.currentTarget.style.opacity=1} onMouseLeave={e=>e.currentTarget.style.opacity=0}>
                    </div>
                  </div>
                  :<div style={{textAlign:"center",padding:"24px 0",color:C.muted}}>
                    <div style={{marginBottom:6,opacity:.5}}>{Icon.img()}</div>
                    <p style={{fontSize:12}}>Drag & drop or click to upload</p>
                    <p style={{fontSize:11,marginTop:2}}>Or enter URL below</p>
                  </div>
                }
                <input id={`imgFile-${i}`} type="file" accept="image/*" style={{display:"none"}} onChange={e=>handleFileUpload(i,e.target.files[0])}/>
              </div>
              <div style={{display:"flex",gap:8}}>
                <input value={img} onChange={e=>setImg(i,e.target.value)} placeholder="https://… or upload above" className="tc-input" style={{flex:1,fontSize:12}}/>
                {form.images.length>1&&<button onClick={()=>removeImg(i)} style={{padding:"8px 10px",borderRadius:7,border:"1px solid #FECACA",background:"#FEF2F2",cursor:"pointer",color:"#C42A2A",display:"flex",alignItems:"center"}}>{Icon.trash()}</button>}
              </div>
            </div>
          ))}
          {form.images.length<4&&<button onClick={addImg} style={{width:"100%",padding:"10px",borderRadius:10,border:`1.5px dashed ${C.border}`,background:"transparent",cursor:"pointer",fontSize:13,color:C.muted,display:"flex",alignItems:"center",justifyContent:"center",gap:6}}>
            {Icon.plus()} Add another image
          </button>}
        </div>
        {/* Save */}
        <div style={{marginTop:16,display:"flex",gap:10}}>
          <Btn full size="lg" onClick={submit}>{product?"Save Changes":"Add Product"}</Btn>
        </div>
      </div>
    </div>
  </div>;
}

function AdminOrders({orders,products,onUpdateStatus}){
  const [filter,setFilter]=useState("all");
  const sorted=[...orders].sort((a,b)=>b.date-a.date);
  const filtered=filter==="all"?sorted:sorted.filter(o=>o.status===filter);

  return <div className="tc-fade">
    <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:24,flexWrap:"wrap",gap:12}}>
      <h2 className="tc-serif" style={{fontSize:24,color:C.dark}}>Orders</h2>
      <div style={{display:"flex",gap:8,flexWrap:"wrap"}}>
        {["all","processing","shipped","delivered","cancelled"].map(s=>(
          <button key={s} onClick={()=>setFilter(s)} style={{padding:"6px 14px",borderRadius:20,border:`1.5px solid ${filter===s?C.gold:C.border}`,background:filter===s?C.goldL:"transparent",fontSize:11,fontWeight:600,cursor:"pointer",color:filter===s?C.goldD:C.muted,textTransform:"capitalize"}}>
            {s==="all"?"All":ORDER_STATUS[s]?.l||s}
          </button>
        ))}
      </div>
    </div>
    <div style={{display:"flex",flexDirection:"column",gap:14}}>
      {filtered.map(o=>{
        const s=ORDER_STATUS[o.status]||{l:o.status,c:"#666",bg:"#eee"};
        return <div key={o.id} style={{background:C.white,borderRadius:14,border:`1px solid ${C.border}`,overflow:"hidden"}}>
          <div style={{padding:"14px 18px",display:"flex",justifyContent:"space-between",alignItems:"center",flexWrap:"wrap",gap:10,borderBottom:`1px solid ${C.border}`}}>
            <div>
              <div style={{display:"flex",gap:10,alignItems:"center",marginBottom:3}}>
                <span style={{fontWeight:700,fontSize:13,color:C.dark}}>{o.id}</span>
                <span className="pill" style={{background:s.bg,color:s.c,fontSize:10}}>{s.l}</span>
              </div>
              <p style={{fontSize:12,color:C.muted}}>{o.name} · {o.email} · {timeAgo(o.date)}</p>
            </div>
            <div style={{display:"flex",gap:8,alignItems:"center"}}>
              <span className="tc-serif" style={{fontSize:18,fontWeight:700,color:C.gold}}>${o.total.toFixed(2)}</span>
              <select value={o.status} onChange={e=>onUpdateStatus(o.id,e.target.value)}
                style={{padding:"6px 10px",borderRadius:8,border:`1px solid ${C.border}`,fontSize:11,background:C.white,color:C.text,cursor:"pointer",fontFamily:"'Jost',sans-serif"}}>
                {Object.entries(ORDER_STATUS).map(([k,v])=><option key={k} value={k}>{v.l}</option>)}
              </select>
            </div>
          </div>
          <div style={{padding:"12px 18px"}}>
            {o.items.map((item,i)=>(
              <div key={i} style={{display:"flex",gap:10,alignItems:"center",padding:"5px 0",borderBottom:i<o.items.length-1?`1px solid ${C.border}`:"none"}}>
                <div style={{flex:1,fontSize:13,color:C.text}}>{item.name}</div>
                <span style={{fontSize:11,color:C.muted}}>Size: {item.size}</span>
                <span style={{fontSize:11,color:C.muted}}>×{item.qty}</span>
                <span style={{fontSize:13,fontWeight:600,color:C.dark}}>${(item.price*item.qty).toFixed(2)}</span>
              </div>
            ))}
            <p style={{fontSize:11,color:C.muted,marginTop:8}}>📍 {o.address}</p>
          </div>
        </div>;
      })}
      {filtered.length===0&&<div style={{textAlign:"center",padding:"60px 0",background:C.white,borderRadius:16,border:`1px solid ${C.border}`}}>
        <p style={{fontSize:14,color:C.muted}}>No orders found</p>
      </div>}
    </div>
  </div>;
}

// ─── MAIN APP ─────────────────────────────────────────────────────────────────
export default function App(){
  const [page,setPage]=useState("home");
  const [products,setProducts]=useState([]);
  const [orders,setOrders]=useState([]);
  const [cart,setCart]=useState([]);
  const [wishlist,setWishlist]=useState([]);
  const [currentProduct,setCurrentProduct]=useState(null);
  const [adminLoggedIn,setAdminLoggedIn]=useState(false);
  const [cartOpen,setCartOpen]=useState(false);
  const [searchQ,setSearchQ]=useState("");
  const [catFilter,setCatFilter]=useState("all");
  const [mobileOpen,setMobileOpen]=useState(false);
  const [loaded,setLoaded]=useState(false);
  const {toasts,add:toast,remove:removeToast}=useToast();

  // Load persisted data on mount
  useEffect(()=>{
    (async()=>{
      const p=await db.get("teema_products");
      const o=await db.get("teema_orders");
      const c=await db.get("teema_cart");
      const w=await db.get("teema_wishlist");
      const a=await db.get("teema_admin");
      setProducts(p||SEED_PRODUCTS);
      setOrders(o||SEED_ORDERS);
      setCart(c||[]);
      setWishlist(w||[]);
      if(a)setAdminLoggedIn(true);
      setLoaded(true);
    })();
  },[]);

  // Persist whenever data changes
  useEffect(()=>{if(loaded)db.set("teema_products",products);},[products,loaded]);
  useEffect(()=>{if(loaded)db.set("teema_orders",orders);},[orders,loaded]);
  useEffect(()=>{if(loaded)db.set("teema_cart",cart);},[cart,loaded]);
  useEffect(()=>{if(loaded)db.set("teema_wishlist",wishlist);},[wishlist,loaded]);

  const cartCount=cart.reduce((s,i)=>s+i.qty,0);
  const wishCount=wishlist.length;

  const navigate=(p)=>{setPage(p);setMobileOpen(false);window.scrollTo(0,0);};

  const handleViewProduct=(product)=>{setCurrentProduct(product);navigate("product");};

  const handleAddCart=(product,size,qty=1)=>{
    if(!size&&product.sizes.length>0){handleViewProduct(product);return;}
    setCart(prev=>{
      const s=size||product.sizes[0];
      const existing=prev.find(i=>i.productId===product.id&&i.size===s);
      if(existing)return prev.map(i=>i.productId===product.id&&i.size===s?{...i,qty:i.qty+qty}:i);
      return [...prev,{productId:product.id,size:s,qty}];
    });
    toast(`${product.name} added to bag`,"🛍");
    setCartOpen(true);
  };

  const handleWishlist=(id)=>{
    setWishlist(prev=>{
      const n=prev.includes(id)?prev.filter(x=>x!==id):[...prev,id];
      toast(prev.includes(id)?"Removed from wishlist":"Saved to wishlist",prev.includes(id)?"💔":"❤️");
      return n;
    });
  };

  const updateCartQty=(productId,size,qty)=>{
    if(qty<1){setCart(prev=>prev.filter(i=>!(i.productId===productId&&i.size===size)));return;}
    setCart(prev=>prev.map(i=>i.productId===productId&&i.size===size?{...i,qty}:i));
  };

  const removeCartItem=(productId,size)=>setCart(prev=>prev.filter(i=>!(i.productId===productId&&i.size===size)));

  const handleSaveProduct=(product)=>{
    setProducts(prev=>{
      const idx=prev.findIndex(p=>p.id===product.id);
      if(idx>=0){const n=[...prev];n[idx]=product;return n;}
      return [product,...prev];
    });
  };

  const handleDeleteProduct=(id)=>{
    setProducts(prev=>prev.filter(p=>p.id!==id));
    setCart(prev=>prev.filter(i=>i.productId!==id));
    setWishlist(prev=>prev.filter(x=>x!==id));
  };

  const handleOrderPlace=(order)=>{
    setOrders(prev=>[order,...prev]);
    setCart([]);
  };

  const handleUpdateOrder=(id,status)=>{
    setOrders(prev=>prev.map(o=>o.id===id?{...o,status}:o));
  };

  const handleAdminLogin=()=>{setAdminLoggedIn(true);db.set("teema_admin","1");};
  const handleAdminLogout=()=>{setAdminLoggedIn(false);db.set("teema_admin","");navigate("home");};

  if(!loaded)return <div style={{minHeight:"100vh",display:"flex",alignItems:"center",justifyContent:"center",background:C.bg,flexDirection:"column",gap:16}}>
    <div className="tc-serif" style={{fontSize:26,color:C.dark}}>Teema's <span style={{color:C.gold}}>Collections</span></div>
    <div style={{display:"flex",gap:6}}>
      {[0,1,2].map(i=>(
        <div key={i} style={{width:8,height:8,borderRadius:"50%",background:C.gold,animation:`bounce 1.2s ${i*0.15}s infinite`}}/>
      ))}
    </div>
    <style>{`@keyframes bounce{0%,80%,100%{transform:scale(0)}40%{transform:scale(1)}}`}</style>
  </div>;

  const navProps={page,setPage:navigate,cartCount,wishCount,searchQ,setSearchQ:(q)=>{setSearchQ(q);},mobileOpen,setMobileOpen};

  return <div style={{minHeight:"100vh",background:C.bg,fontFamily:"'Jost',sans-serif"}}>
    {page!=="admin"&&<Navbar {...navProps}/>}

    {page==="home"&&<HomePage products={products} onView={handleViewProduct} onCart={handleAddCart} onWish={handleWishlist} wishlist={wishlist} setPage={navigate}/>}
    {page==="shop"&&<ShopPage products={products} onView={handleViewProduct} onCart={handleAddCart} onWish={handleWishlist} wishlist={wishlist} searchQ={searchQ} catFilter={catFilter} setCatFilter={setCatFilter}/>}
    {page==="product"&&currentProduct&&<ProductDetailPage product={currentProduct} onCart={handleAddCart} onWish={handleWishlist} wishlist={wishlist} products={products} onView={handleViewProduct} setPage={navigate}/>}
    {page==="wishlist"&&<WishlistPage wishlist={wishlist} products={products} onView={handleViewProduct} onCart={handleAddCart} onWish={handleWishlist} setPage={navigate}/>}
    {page==="cart"&&<CheckoutPage cart={cart} products={products} onOrderPlace={handleOrderPlace} setPage={navigate}/>}
    {page==="checkout"&&<CheckoutPage cart={cart} products={products} onOrderPlace={handleOrderPlace} setPage={navigate}/>}
    {page==="admin"&&(adminLoggedIn
      ?<AdminDashboard products={products} orders={orders} onLogout={handleAdminLogout} onSaveProduct={handleSaveProduct} onDeleteProduct={handleDeleteProduct} onUpdateOrder={handleUpdateOrder} toast={toast} setPage={navigate}/>
      :<AdminLogin onLogin={handleAdminLogin}/>
    )}

    {page!=="admin"&&<Footer setPage={navigate}/>}

    <CartDrawer open={cartOpen} onClose={()=>setCartOpen(false)} cart={cart} products={products} updateQty={updateCartQty} removeItem={removeCartItem} setPage={navigate}/>

    <Toast toasts={toasts} remove={removeToast}/>
  </div>;
}